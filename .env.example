# AWS S3 credentials for integration tests against a real bucket.
# If AWS_S3_BUCKET is set, tests run against live AWS S3.
# Otherwise, tests run against a local s3rver mock (no credentials needed).
#
# AWS_S3_BUCKET=my-test-bucket
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
